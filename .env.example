# ============================================================
# AI Model API Keys (fill in the ones you want to use)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_GENERATIVE_AI_API_KEY=xxx
MINIMAX_API_KEY=sk-xxx
MINIMAX_EMBED_API_KEY=sk-xxx
JINA_API_KEY=jina_xxx

# ============================================================
# Model Configuration (flexible switching)
# ============================================================
# 轻量任务模型（Feed 消化用）
# 可选: claude-haiku / gpt-4o-mini / gemini-flash
AI_LIGHT_MODEL=claude-haiku

# 重度任务模型（Think 思考用）
# 可选: claude-sonnet / claude-opus / gpt-4o / gemini-pro / deepseek
AI_HEAVY_MODEL=claude-sonnet

# 评估模型（可选，未设置时回退到 AI_LIGHT_MODEL）
AI_EVAL_MODEL=claude-haiku

# 嵌入模型
AI_EMBED_MODEL=text-embedding-3-small

# 如果 MINIMAX_API_KEY 是 Coding Plan Key（sk-cp-...），
# 请单独为 embeddings 配一个普通按量付费 Key 到 MINIMAX_EMBED_API_KEY

# 是否暂时关闭 embeddings（1 = 关闭，0/空 = 开启）
AI_DISABLE_EMBEDDINGS=0

# Embedding provider 优先级，可选: openai,minimax,jina
AI_EMBED_PROVIDER_ORDER=openai,minimax,jina

# ============================================================
# Supabase Database
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx
